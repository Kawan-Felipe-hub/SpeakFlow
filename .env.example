# Django
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
APP_ENV=dev
USE_SQLITE=true

# Database (PostgreSQL - for production/Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/speakflow
POSTGRES_DB=speakflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

### JWT (SimpleJWT)
JWT_SIGNING_KEY=dev-jwt-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

### Groq (LLM)
git GROQ_API_KEY=minha-chave
GROQ_MODEL=llama-3.3-70b-versatile

### Azure Speech (STT/TTS/Pronunciation)
AZURE_SPEECH_KEY=outra-chave
AZURE_SPEECH_REGION=brazilsouth
AZURE_SPEECH_LANGUAGE=en-US
AZURE_SPEECH_VOICE=en-US-JennyNeural
AZURE_STT_TIMEOUT_S=20
AZURE_TTS_TIMEOUT_S=20

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Base URL
BASE_URL=http://localhost:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
